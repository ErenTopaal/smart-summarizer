generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  free_user
  pro_user
  premium_user
  admin
}

enum SubscriptionStatus {
  active
  inactive
  canceled
  past_due
  trialing
}

enum SubscriptionPlan {
  free
  pro
  premium
}

enum SummaryMode {
  lesson
  business
  medical
  legal
  academic
  social_media
  general
}

enum FileStatus {
  pending
  processing
  completed
  failed
}

enum FileType {
  pdf
  docx
  txt
  pptx
  mp3
  wav
  m4a
  mp4
  png
  jpg
  jpeg
  url
  youtube
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  emailVerified      DateTime?
  name               String?
  username           String?             @unique
  passwordHash       String?
  image              String?
  role               UserRole            @default(free_user)
  bio                String?
  timezone           String              @default("UTC")
  language           String              @default("tr")
  isActive           Boolean             @default(true)
  isBanned           Boolean             @default(false)
  banReason          String?
  bannedAt           DateTime?
  bannedBy           String?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  accounts           Account[]
  summaries          Summary[]
  files              File[]
  subscription       Subscription?
  payments           Payment[]
  usageLogs          UsageLog[]
  quizResults        QuizResult[]
  favorites          Favorite[]
  notifications      Notification[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  dailySummaryLimit    Int                @default(3)
  fileSizeLimitMB      Int                @default(5)
  monthlyTokenLimit    Int                @default(50000)
  tokensUsedThisMonth  Int                @default(0)
  summariesUsedToday   Int                @default(0)
  lastResetDate        DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String
  stripePaymentIntentId String?  @unique
  amount                Int
  currency              String   @default("usd")
  status                String
  description           String?
  metadata              Json?
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model File {
  id           String     @id @default(cuid())
  userId       String
  originalName String
  storagePath  String
  storageUrl   String?
  mimeType     String
  fileType     FileType
  sizeBytes    Int
  status       FileStatus @default(pending)
  errorMessage String?
  metadata     Json?
  processedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  summaries    Summary[]
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Summary {
  id                 String      @id @default(cuid())
  userId             String
  fileId             String?
  title              String
  mode               SummaryMode @default(general)
  inputText          String?     @db.Text
  inputUrl           String?
  shortSummary       String?     @db.Text
  detailedSummary    String?     @db.Text
  bulletPoints       Json?
  keywords           Json?
  tasks              Json?
  quiz               Json?
  flashcards         Json?
  medicalTerms       Json?
  importantSentences Json?
  lockedKeywords     Json?
  language           String      @default("tr")
  aiProvider         String?
  aiModel            String?
  tokensUsed         Int         @default(0)
  processingTimeMs   Int?
  isPublic           Boolean     @default(false)
  isFavorite         Boolean     @default(false)
  tags               Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  file               File?       @relation(fields: [fileId], references: [id], onDelete: SetNull)
  quizResults        QuizResult[]
  favorites          Favorite[]

  @@index([userId])
  @@index([mode])
  @@index([createdAt])
}

model QuizResult {
  id          String   @id @default(cuid())
  userId      String
  summaryId   String
  score       Int
  totalPoints Int
  answers     Json
  timeSpentMs Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary     Summary  @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([summaryId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  summaryId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   Summary  @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@unique([userId, summaryId])
  @@index([userId])
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String?
  resourceId   String?
  tokensUsed   Int      @default(0)
  costUsd      Float    @default(0)
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  targetType  String?
  targetId    String?
  description String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}
